<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\.editorconfig" Link=".editorconfig" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.11" />
    <PackageReference Include="bodong.Avalonia.PropertyGrid" Version="11.3.11.1" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.11" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.11" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0-preview.5.24306.7" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.0-preview.5.24306.7" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Serilog" Version="3.1.1" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="8.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LocalAutomation.Application\LocalAutomation.Application.csproj" />
    <ProjectReference Include="..\LocalAutomation.Persistence\LocalAutomation.Persistence.csproj" />
    <ProjectReference Include="..\LocalAutomation.Extensions.Abstractions\LocalAutomation.Extensions.Abstractions.csproj" />
  </ItemGroup>

  <Target Name="CopyBundledExtensions" AfterTargets="Build">
    <PropertyGroup>
      <BundledExtensionsRoot>$(OutputPath)Extensions\</BundledExtensionsRoot>
    </PropertyGroup>

    <RemoveDir Directories="$(BundledExtensionsRoot)" Condition="Exists('$(BundledExtensionsRoot)')" />
    <MakeDir Directories="$(BundledExtensionsRoot)" />

    <ItemGroup>
      <BundledExtensionProject Include="..\LocalAutomation.Extensions.Unreal\LocalAutomation.Extensions.Unreal.csproj">
        <ExtensionFolderName>Unreal</ExtensionFolderName>
        <ExtensionTargetFramework>netstandard2.1</ExtensionTargetFramework>
      </BundledExtensionProject>
    </ItemGroup>

    <MSBuild Projects="@(BundledExtensionProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration)" />

    <ItemGroup>
      <BundledExtensionFiles Include="..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\**\*.*"
                             Exclude="..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Application.dll;..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Application.pdb;..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Core.dll;..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Core.pdb;..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Extensions.Abstractions.dll;..\LocalAutomation.Extensions.Unreal\bin\$(Configuration)\netstandard2.1\LocalAutomation.Extensions.Abstractions.pdb">
        <ExtensionFolderName>Unreal</ExtensionFolderName>
      </BundledExtensionFiles>
      <BundledExtensionDirectories Include="@(BundledExtensionFiles->'$(BundledExtensionsRoot)%(ExtensionFolderName)\%(RecursiveDir)')" />
    </ItemGroup>

    <MakeDir Directories="@(BundledExtensionDirectories)" Condition="@(BundledExtensionDirectories) != ''" />

    <Copy SourceFiles="@(BundledExtensionFiles)"
          DestinationFiles="@(BundledExtensionFiles->'$(BundledExtensionsRoot)%(ExtensionFolderName)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="@(BundledExtensionFiles) != ''" />
  </Target>

</Project>
