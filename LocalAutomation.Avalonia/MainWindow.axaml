<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        xmlns:pgc="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
        xmlns:ext="clr-namespace:LocalAutomation.Extensions.Abstractions;assembly=LocalAutomation.Extensions.Abstractions"
        x:Class="LocalAutomation.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LocalAutomation"
        Width="1240"
        Height="820"
        MinWidth="960"
        MinHeight="680">
    <!-- The window now mirrors the Obsidian Graphite mockup: compact chrome, hard dividers, and stacked workspace panels. -->
    <Grid Margin="10" RowDefinitions="*">

        <!-- The main split keeps targets fixed on the left and the stacked workflow on the right. -->
        <Grid ColumnDefinitions="280,*" ColumnSpacing="10">

            <!-- The targets rail keeps selection context, actions, and compatibility in one place. -->
            <Border Classes="panel">
                <Grid RowDefinitions="Auto,*,Auto" MinHeight="0">
                    <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBlock Text="TARGETS" Classes="panel-title" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Classes="small"
                                    Content="+ Add"
                                    Click="BrowseTarget_Click" />
                        </Grid>
                    </Border>

                    <!-- Let the ListBox own scrolling so its item width stays aligned with the visible viewport. -->
                    <ListBox Grid.Row="1"
                             Margin="8,8,8,0"
                             Classes="targets-list"
                             ItemsSource="{Binding Targets}"
                             SelectedItem="{Binding SelectedTarget}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TargetListItemViewModel">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <!-- The title/path stack owns the flexible column so long target paths truncate without hiding the display name. -->
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TargetPath}" Classes="muted" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TypeName}" Classes="muted" />
                                    </StackPanel>
                                    <!-- The type badge stays in the auto column so it sizes to its label instead of stretching across the row. -->
                                    <Border Grid.Column="1" Classes="pill" Padding="6,2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TypeName}" FontSize="10" FontWeight="Bold" Classes="muted" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Selected-target details stay separated from the scrollable list so actions remain easy to reach. -->
                    <Border Grid.Row="2" Padding="12,12,12,12" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SELECTED" Classes="detail-label" />
                            <TextBlock Text="{Binding SelectedTargetSummary}" Classes="soft" />
                            <TextBlock Text="{Binding SelectedTargetPath}" Classes="muted" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTargetEngine}" Classes="muted" />
                        </StackPanel>

                        <WrapPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding TargetActions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TargetContextActionViewModel">
                                        <Button Classes="subtle small"
                                                Margin="0,0,6,6"
                                                Content="{Binding DisplayName}"
                                                Click="TargetAction_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Classes="danger small"
                                    Margin="0,0,6,6"
                                    Content="Remove"
                                    Click="RemoveSelectedTarget_Click" />
                        </WrapPanel>

                        <Border Classes="card" Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="COMPATIBILITY" Classes="detail-label" />
                                <TextBlock Text="{Binding ExecuteButtonText}" Classes="soft" />
                                <TextBlock Text="{Binding OperationSupportsMultipleEngines, StringFormat='Supports multiple engines: {0}'}"
                                           Classes="muted" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- The right column preserves the options-command-runtime stack from the reference layout. -->
            <Grid Grid.Column="1" RowDefinitions="1.1*,Auto,0.9*" RowSpacing="10" MinHeight="0">

                <!-- Options stay dominant and use compact cards to match the mockup's editing surface. -->
                <Border Classes="panel" Grid.Row="0">
                    <Grid RowDefinitions="Auto,*" MinHeight="0">
                        <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <TextBlock Text="OPTIONS" Classes="panel-title" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          Width="260"
                                          ItemsSource="{Binding AvailableOperations}"
                                          SelectedItem="{Binding SelectedOperation}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ext:OperationDescriptor">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0"
                                      Padding="10,10,10,0"
                                      SizeChanged="OptionsScrollViewer_SizeChanged"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding EnabledOptionSets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- A wrap panel keeps each options card compact while still adapting to the available editor width. -->
                                        <WrapPanel Orientation="Horizontal" ItemWidth="{Binding OptionsCardWidth}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:OptionSetViewModel">
                                        <Border Classes="card" Margin="0,0,10,10" Padding="10,8">
                                            <Grid RowDefinitions="Auto,*">
                                                <TextBlock Text="{Binding Name}" Classes="panel-title" />
                                                <pgc:PropertyGrid Grid.Row="1"
                                                                  Margin="0,10,0,0"
                                                                  DataContext="{Binding PropertyGridTarget}"
                                                                  IsQuickFilterVisible="False"
                                                                  IsCategoryVisible="False"
                                                                  IsHeaderVisible="False"
                                                                  IsTitleVisible="False" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- The command panel stays compact and action-oriented, like the reference command strip. -->
                <Border Classes="panel" Grid.Row="1">
                    <Grid Margin="12,10" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowDefinitions="Auto,*">
                        <TextBlock Text="COMMAND" Classes="field-label" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Classes="small"
                                    Content="Copy"
                                    Click="CopyCommand_Click"
                                    IsEnabled="{Binding CanCopyCommand}" />
                            <Button Classes="primary small"
                                    Content="{Binding ExecuteButtonText}"
                                    Click="Execute_Click"
                                    IsEnabled="{Binding CanExecute}" />
                        </StackPanel>
                        <TextBox Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,8,0,0"
                                 Classes="mono"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="52"
                                 Text="{Binding VisibleCommand}" />
                    </Grid>
                </Border>

                <!-- Runtime uses underlined tabs and a terminal slab so execution feedback matches the mockup tone. -->
                <Border Classes="panel" Grid.Row="2">
                    <Grid RowDefinitions="Auto,Auto,*" MinHeight="0">
                        <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <TextBlock Text="{Binding SelectedRuntimeTabTitle}" Classes="panel-title" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Classes="danger small"
                                        Content="Terminate"
                                        Click="Terminate_Click"
                                        IsEnabled="{Binding IsRunning}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="12,8,12,0" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding RuntimeTabs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RuntimeTaskTabViewModel">
                                            <Button Classes="tab"
                                                    Classes.active="{Binding IsSelected}"
                                                    Content="{Binding Title}"
                                                    Click="RuntimeTab_Click" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2" Margin="12,10,12,12" RowDefinitions="Auto,*" MinHeight="0">
                            <TextBlock Text="{Binding ExecutionSummary}" TextWrapping="Wrap" Classes="muted" />
                            <Border Grid.Row="1" Classes="terminal-shell" Margin="0,8,0,0" Padding="10,10,10,6">
                                <ScrollViewer x:Name="RuntimeLogScrollViewer"
                                              ScrollChanged="RuntimeLogScrollViewer_ScrollChanged"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding SelectedRuntimeLogEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LogEntryViewModel">
                                                <Border Padding="0,0,0,4">
                                                    <!-- SelectableTextBlock preserves copyable logs while keeping the terminal presentation lightweight. -->
                                                    <SelectableTextBlock Text="{Binding Message}"
                                                                         Foreground="{Binding Foreground}"
                                                                         TextWrapping="Wrap"
                                                                         FontFamily="Consolas, Cascadia Mono, monospace"
                                                                         FontSize="12" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
