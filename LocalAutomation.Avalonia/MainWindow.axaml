<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        xmlns:panels="clr-namespace:LocalAutomation.Avalonia.Views.Panels"
        x:Class="LocalAutomation.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1240"
        Height="820"
        MinWidth="960"
        MinHeight="680">
    <!-- The shell uses explicit splitter rows and columns so the options area, right rail, and output panel can be
         resized at runtime without changing panel ownership. -->
    <Grid Margin="10" MinHeight="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="420" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="520" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="6" />
            <RowDefinition Height="0.9*" MinHeight="180" />
        </Grid.RowDefinitions>

        <!-- Let the target rail hug its content so the command preview can take the remaining vertical space and
             scroll within it instead of forcing the target panel to stretch. -->
        <Grid Grid.Column="2" Grid.Row="0" RowDefinitions="Auto,*" RowSpacing="6" MinHeight="0">
            <panels:TargetPanel DataContext="{Binding Target}" VerticalAlignment="Top" />
            <panels:CommandPanel Grid.Row="1" MinHeight="0" />
        </Grid>

        <GridSplitter Grid.Column="1"
                      Grid.Row="0"
                      ResizeDirection="Columns"
                      Classes="resize-handle-vertical" />

        <panels:OptionsPanel Grid.Column="0" Grid.Row="0" />

        <GridSplitter Grid.ColumnSpan="3"
                       Grid.Row="1"
                       ResizeDirection="Rows"
                       Classes="resize-handle-horizontal" />

        <panels:RuntimePanel Grid.Row="2" Grid.ColumnSpan="3" DataContext="{Binding Runtime}" />
    </Grid>
</Window>
