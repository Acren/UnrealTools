<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        xmlns:panels="clr-namespace:LocalAutomation.Avalonia.Views.Panels"
        x:Class="LocalAutomation.Avalonia.MainWindow"
        x:Name="Main"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="Full"
        Width="1240"
        Height="820"
        MinWidth="960"
        MinHeight="680">
    <Panel>
        <!-- Keep the settings action in the extended title bar by aligning it directly against the window instead of
             offsetting it with WindowDecorationMargin, which pushes normal content below the chrome area. -->
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,3,144,0"
                Classes="subtle"
                Width="24"
                Height="24"
                MinWidth="24"
                MinHeight="24"
                Padding="0,0"
                Foreground="{DynamicResource GraphiteTextSoftBrush}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                ToolTip.Tip="Settings"
                Click="OpenSettings_Click">
            <icons:PathIcon Data="M10,1.5 L11.2,1.5 L11.8,3.3 C12.5,3.5 13.1,3.8 13.7,4.1 L15.4,3.2 L16.3,4.1 L15.4,5.8 C15.8,6.3 16.1,6.9 16.3,7.6 L18.1,8.2 L18.1,9.5 L16.3,10.1 C16.1,10.8 15.8,11.4 15.4,11.9 L16.3,13.6 L15.4,14.5 L13.7,13.6 C13.1,14 12.5,14.2 11.8,14.5 L11.2,16.3 L10,16.3 L9.4,14.5 C8.7,14.2 8.1,14 7.5,13.6 L5.8,14.5 L4.9,13.6 L5.8,11.9 C5.4,11.4 5.2,10.8 4.9,10.1 L3.1,9.5 L3.1,8.2 L4.9,7.6 C5.2,6.9 5.4,6.3 5.8,5.8 L4.9,4.1 L5.8,3.2 L7.5,4.1 C8.1,3.8 8.7,3.5 9.4,3.3 Z M10.6,6.2 C9.1,6.2 7.9,7.4 7.9,8.9 C7.9,10.4 9.1,11.6 10.6,11.6 C12.1,11.6 13.3,10.4 13.3,8.9 C13.3,7.4 12.1,6.2 10.6,6.2 Z"
                            Width="14"
                            Height="14"
                            Foreground="{Binding $parent[Button].Foreground}" />
        </Button>

        <Grid Margin="{Binding #Main.OffScreenMargin}">
            <!-- The content layout stays offset by the live window decoration margins so the title bar remains native. -->
            <Grid Margin="{Binding #Main.WindowDecorationMargin}"
                  RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        IsVisible="{Binding ShowStartupMessage}"
                        Margin="10,0,10,10"
                        Background="{DynamicResource GraphiteDangerBackgroundBrush}"
                        BorderBrush="{DynamicResource GraphiteDangerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,10">
                    <SelectableTextBlock Text="{Binding StartupMessage}"
                                         Classes="status-danger"
                                         TextWrapping="Wrap" />
                </Border>

                <!-- The shell uses explicit splitter rows and columns so the options area, right rail, and output panel can
                     be resized at runtime without changing panel ownership. -->
                <Grid Grid.Row="1" Margin="10" MinHeight="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="280" MinWidth="220" MaxWidth="520" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="260" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="0.9*" MinHeight="180" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Column="2" Grid.Row="0" RowDefinitions="*,Auto" RowSpacing="10" MinHeight="0">
                        <panels:TargetPanel DataContext="{Binding Target}" />
                        <panels:CommandPanel Grid.Row="1" />
                    </Grid>

                    <GridSplitter Grid.Column="1"
                                  Grid.Row="0"
                                  ResizeDirection="Columns"
                                  Classes="resize-handle-vertical" />

                    <panels:OptionsPanel Grid.Column="0" Grid.Row="0" />

                    <GridSplitter Grid.ColumnSpan="3"
                                   Grid.Row="1"
                                   ResizeDirection="Rows"
                                   Classes="resize-handle-horizontal" />

                    <panels:RuntimePanel Grid.Row="2" Grid.ColumnSpan="3" DataContext="{Binding Runtime}" />
                </Grid>
            </Grid>
        </Grid>
    </Panel>
</Window>
