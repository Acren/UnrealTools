<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        xmlns:pgc="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
        xmlns:ext="clr-namespace:LocalAutomation.Extensions.Abstractions;assembly=LocalAutomation.Extensions.Abstractions"
        x:Class="LocalAutomation.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LocalAutomation"
        Width="1240"
        Height="820"
        MinWidth="960"
        MinHeight="680">
    <!-- The window now mirrors the Obsidian Graphite mockup: compact chrome, hard dividers, and stacked workspace panels. -->
    <Grid Margin="10" RowDefinitions="*">

        <!-- The shell keeps controls in the upper split and gives runtime output a full-width panel underneath. -->
        <Grid RowDefinitions="*,0.9*" RowSpacing="10" ColumnDefinitions="*,280" ColumnSpacing="10">

            <!-- The right rail now stacks targets above the command preview so both share the same narrow control column. -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="10" MinHeight="0">

            <!-- The targets rail keeps target selection and target-scoped actions compact. -->
            <Border Classes="panel">
                <Grid RowDefinitions="Auto,Auto,*" MinHeight="0">
                    <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                        <TextBlock Text="TARGET" Classes="panel-title" VerticalAlignment="Center" />
                    </Border>

                    <ComboBox Grid.Row="1"
                              Margin="8,8,8,0"
                              ItemsSource="{Binding TargetPickerItems}"
                              SelectedItem="{Binding SelectedTargetPickerItem}"
                              MaxDropDownHeight="360"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="TargetPicker_SelectionChanged">
                        <ComboBox.SelectionBoxItemTemplate>
                            <DataTemplate x:DataType="vm:TargetPickerItemViewModel">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TargetPath}" FontSize="12" Classes="muted" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Classes="pill" Padding="6,2" VerticalAlignment="Top" HorizontalAlignment="Right" IsVisible="{Binding IsTargetItem}">
                                        <TextBlock Text="{Binding TypeName}" FontSize="10" FontWeight="Bold" Classes="muted" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.SelectionBoxItemTemplate>
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TargetPickerItemViewModel">
                                <Grid>
                                    <!-- Real targets keep the richer two-line layout, with the badge aligned beside the name to free the full row for the path. -->
                                    <StackPanel IsVisible="{Binding IsTargetItem}" Spacing="2">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Classes="pill" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TypeName}" FontSize="10" FontWeight="Bold" Classes="muted" />
                                            </Border>
                                            <Button Grid.Column="2"
                                                    Classes="small subtle"
                                                    Padding="4,0"
                                                    MinWidth="24"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Content="X"
                                                    Click="RemoveTargetPickerItem_Click" />
                                        </Grid>
                                        <TextBlock Text="{Binding TargetPath}" FontSize="12" Classes="muted" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- The synthetic add row uses a dedicated minimal layout so it reads like an action, not a target. -->
                                    <Border IsVisible="{Binding IsAddAction}"
                                            Padding="6,4"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                        <TextBlock Text="{Binding AddActionLabel}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Classes="soft" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Target actions stay visually separated from the picker and share the available row width evenly. -->
                    <Border Grid.Row="2"
                            Margin="8,10,8,8"
                            Padding="0"
                            BorderBrush="{DynamicResource GraphiteLineBrush}"
                            BorderThickness="0,1,0,0">
                    <StackPanel Spacing="6" Margin="0,10,0,0">
                        <ItemsControl ItemsSource="{Binding TargetActions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TargetContextActionViewModel">
                                    <Button Classes="small"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Content="{Binding DisplayName}"
                                            Click="TargetAction_Click" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- The command preview moves into the left rail so it matches the targets panel width. -->
            <Border Classes="panel" Grid.Row="1">
                <Grid RowDefinitions="Auto,*,Auto" MinHeight="0">
                    <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                        <TextBlock Text="COMMAND" Classes="field-label" />
                    </Border>
                    <Border Grid.Row="1" Background="{DynamicResource GraphiteTerminalBrush}">
                        <ScrollViewer Margin="12,10,12,12"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <SelectableTextBlock Classes="mono"
                                                 Text="{Binding VisibleCommand}"
                                                 TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Row="2" Padding="12,10,12,12" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Classes="small"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Copy"
                                    Click="CopyCommand_Click"
                                    IsEnabled="{Binding CanCopyCommand}" />
                            <Button Grid.Column="1"
                                    Classes="primary small"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding ExecuteButtonText}"
                                    Click="Execute_Click"
                                    IsEnabled="{Binding CanExecute}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            </Grid>

            <!-- The upper-left column is now dedicated to operations and options, while runtime output spans the full width below. -->
            <Grid MinHeight="0">

                <!-- Options stay dominant and use compact cards to match the mockup's editing surface. -->
                <Border Classes="panel" Grid.Row="0">
                    <Grid RowDefinitions="Auto,*" MinHeight="0">
                        <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                                <TextBlock Text="OPERATION" Classes="panel-title" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          Width="260"
                                          HorizontalAlignment="Left"
                                          ItemsSource="{Binding AvailableOperations}"
                                          SelectedItem="{Binding SelectedOperation}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="ext:OperationDescriptor">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0"
                                      Padding="10,10,10,0"
                                      SizeChanged="OptionsScrollViewer_SizeChanged"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding OptionColumns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- Independent vertical columns avoid the row-height stretching that wrap-based layouts introduce. -->
                                        <StackPanel Orientation="Horizontal" Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:OptionColumnViewModel">
                                        <ItemsControl ItemsSource="{Binding Items}" Width="{Binding CardWidth}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical" Spacing="10" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:OptionSetViewModel">
                                                    <Border Classes="card" Padding="10,8" SizeChanged="OptionCard_SizeChanged">
                                                        <Grid RowDefinitions="Auto,*">
                                                            <TextBlock Text="{Binding Name}" Classes="panel-title" />
                                                            <pgc:PropertyGrid Grid.Row="1"
                                                                              Margin="0,10,0,0"
                                                                              DataContext="{Binding PropertyGridTarget}"
                                                                              IsQuickFilterVisible="False"
                                                                              IsCategoryVisible="False"
                                                                              IsHeaderVisible="False"
                                                                              IsTitleVisible="False" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>

            <!-- Runtime uses underlined tabs and a terminal slab so execution feedback matches the mockup tone. -->
            <Border Classes="panel" Grid.Row="1" Grid.ColumnSpan="2">
                <Grid RowDefinitions="Auto,*" MinHeight="0">
                    <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding RuntimeTabs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RuntimeTaskTabViewModel">
                                            <Button Classes="tab"
                                                    Classes.active="{Binding IsSelected}"
                                                    Content="{Binding Title}"
                                                    Click="RuntimeTab_Click" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Button Grid.Column="1"
                                    Classes="danger small"
                                    Content="Terminate"
                                    Click="Terminate_Click"
                                    IsEnabled="{Binding IsRunning}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Margin="0" Background="{DynamicResource GraphiteTerminalBrush}">
                        <ScrollViewer x:Name="RuntimeLogScrollViewer"
                                      Margin="12,10,12,12"
                                      ScrollChanged="RuntimeLogScrollViewer_ScrollChanged"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding SelectedRuntimeLogEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogEntryViewModel">
                                        <Border Padding="0,0,0,4">
                                            <!-- SelectableTextBlock preserves copyable logs while keeping the terminal presentation lightweight. -->
                                            <SelectableTextBlock Text="{Binding Message}"
                                                                 Foreground="{Binding Foreground}"
                                                                 TextWrapping="Wrap"
                                                                 FontFamily="Consolas, Cascadia Mono, monospace"
                                                                 FontSize="12" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
