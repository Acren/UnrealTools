<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        xmlns:panels="clr-namespace:LocalAutomation.Avalonia.Views.Panels"
        x:Class="LocalAutomation.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LocalAutomation"
        Width="1240"
        Height="820"
        MinWidth="960"
        MinHeight="680">
    <!-- The window now acts as a composition shell that delegates each workspace region to a focused panel view. -->
    <Grid Margin="10" RowDefinitions="*">
        <Grid RowDefinitions="*,0.9*" RowSpacing="10" ColumnDefinitions="*,280" ColumnSpacing="10">
            <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="10" MinHeight="0">
                <panels:TargetPanel />
                <panels:CommandPanel Grid.Row="1" />
            </Grid>

            <panels:OptionsPanel />

            <panels:RuntimePanel Grid.Row="1" Grid.ColumnSpan="2" />
        </Grid>
    </Grid>
</Window>
