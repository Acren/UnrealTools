<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
        xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
        x:Class="LocalAutomation.Avalonia.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Width="640"
        Height="480"
        MinWidth="540"
        MinHeight="380"
        Title="Settings">
    <!-- This window keeps global preferences isolated from target or session editing flows. -->
    <Grid Margin="10" RowDefinitions="*,Auto" RowSpacing="10">
        <Border Classes="panel" Padding="10" MinHeight="0">
            <controls:SettingsPropertyGrid DataContext="{Binding PropertyGridTarget}"
                                           IsQuickFilterVisible="False"
                                           IsAutoNameWidth="False"
                                           IsCategoryVisible="False"
                                           IsHeaderVisible="False"
                                           IsTitleVisible="False"
                                           NameWidth="400" />
        </Border>

        <Border Grid.Row="1" Classes="panel" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="1"
                        Classes="primary small"
                        Content="Close"
                        Click="Close_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
