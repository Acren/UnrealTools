<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Controls.StatusIndicator"
             x:DataType="controls:StatusIndicator"
             x:Name="Root"
             ClipToBounds="False">
    <UserControl.Styles>
        <!-- Reuse the tab marker class directly so running, success, and failure keep the original animation/glow
             language, while local styles extend the shared preview, lock-wait, and inactive status groupings.
             Cancelled and Skipped stay in the neutral queued palette, while Disabled and Interrupted deliberately read
             quieter. -->
        <Style Selector="Border.status-indicator-dot.pending, Border.status-indicator-dot.planned, Border.status-indicator-dot.cancelled, Border.status-indicator-dot.skipped">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusQueuedBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <!-- Dependency wait needs a distinct external-blocker hue, while lock wait should read as active contention
             without colliding with the running blue. -->
        <Style Selector="Border.status-indicator-dot.awaiting-dependency">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusAwaitingDependencyBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Opacity" Value="0.88" />
        </Style>
        <Style Selector="Border.status-indicator-dot.awaiting-lock">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusAwaitingLockBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Opacity" Value="0.84" />
        </Style>
        <Style Selector="Border.status-indicator-dot.interrupted, Border.status-indicator-dot.disabled">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusInactiveBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Opacity" Value="0.52" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.pending, TextBlock.status-indicator-label.planned, TextBlock.status-indicator-label.cancelled, TextBlock.status-indicator-label.skipped">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusQueuedBrush}" />
            <Setter Property="Opacity" Value="0.82" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.awaiting-dependency">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusAwaitingDependencyBrush}" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.awaiting-lock">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusAwaitingLockBrush}" />
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.interrupted, TextBlock.status-indicator-label.disabled">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusInactiveBrush}" />
            <Setter Property="Opacity" Value="0.68" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.running">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusRunningBrush}" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.succeeded">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusCompletedBrush}" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.failed">
            <Setter Property="Foreground" Value="{DynamicResource ExecutionStatusFailedBrush}" />
        </Style>
    </UserControl.Styles>
    <!-- One shared status-indicator control keeps tab dots and graph status rows visually aligned while still letting
         each host choose whether the label is shown. The dot sits in a compact dedicated column so the glow can extend
         slightly past the row bounds without adding an obvious left-side spacer before the label. -->
    <Grid ColumnDefinitions="8,Auto"
           RowDefinitions="Auto"
           VerticalAlignment="Center"
           ClipToBounds="False">
        <Border x:Name="DotBorder"
                Classes="runtime-status-dot status-indicator-dot"
                CornerRadius="999"
                Grid.Row="0"
                Grid.Column="0"
                ClipToBounds="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        <TextBlock x:Name="LabelTextBlock"
                   Classes="status-indicator-label"
                   Grid.Row="0"
                   Grid.Column="1"
                    Margin="6,0,0,0"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                   TextAlignment="Left" />
    </Grid>
</UserControl>
