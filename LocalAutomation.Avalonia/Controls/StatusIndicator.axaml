<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Controls.StatusIndicator"
             x:DataType="controls:StatusIndicator"
             x:Name="Root"
             ClipToBounds="False">
    <UserControl.Styles>
        <!-- Reuse the tab marker class directly so running, success, and failure keep the original animation/glow
             language, while local styles extend the shared preview and inactive status groupings. -->
        <Style Selector="Border.status-indicator-dot.pending, Border.status-indicator-dot.planned">
            <Setter Property="Background" Value="#98A9B8" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
        </Style>
        <Style Selector="Border.status-indicator-dot.cancelled, Border.status-indicator-dot.disabled, Border.status-indicator-dot.skipped">
            <Setter Property="Background" Value="#7A838D" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label">
            <Setter Property="Foreground" Value="#A9B5C2" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.pending, TextBlock.status-indicator-label.planned">
            <Setter Property="Foreground" Value="#B3C1CD" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.cancelled, TextBlock.status-indicator-label.disabled, TextBlock.status-indicator-label.skipped">
            <Setter Property="Foreground" Value="#9BA4AD" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.running">
            <Setter Property="Foreground" Value="#A9D2F1" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.succeeded">
            <Setter Property="Foreground" Value="#A9D9BE" />
        </Style>
        <Style Selector="TextBlock.status-indicator-label.failed">
            <Setter Property="Foreground" Value="#F0AAA5" />
        </Style>
    </UserControl.Styles>
    <!-- One shared status-indicator control keeps tab dots and graph status rows visually aligned while still letting
         each host choose whether the label is shown. The dot sits in a compact dedicated column so the glow can extend
         slightly past the row bounds without adding an obvious left-side spacer before the label. -->
    <Grid ColumnDefinitions="8,Auto"
           RowDefinitions="Auto"
           VerticalAlignment="Center"
           ClipToBounds="False">
        <Border x:Name="DotBorder"
                Classes="runtime-status-dot status-indicator-dot"
                CornerRadius="999"
                Grid.Row="0"
                Grid.Column="0"
                ClipToBounds="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        <TextBlock x:Name="LabelTextBlock"
                   Classes="status-indicator-label"
                   Grid.Row="0"
                   Grid.Column="1"
                    Margin="6,0,0,0"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                   TextAlignment="Left" />
    </Grid>
</UserControl>
