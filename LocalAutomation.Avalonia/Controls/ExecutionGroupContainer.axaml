<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Controls.ExecutionGroupContainer"
             x:CompileBindings="False"
             x:Name="Root">
    <UserControl.Styles>
        <!-- Group visuals also use semantic classes so status hue is centralized in styles while hover and selection
             adjust emphasis. Hover uses lighter layered fills so headers read as active affordances. -->
        <Style Selector="Border.group-container-background">
            <Setter Property="Background" Value="#131A24" />
        </Style>
        <Style Selector="Border.group-container-background.selected">
            <Setter Property="Background" Value="#1A2430" />
        </Style>
        <Style Selector="Border.group-container-background.hover">
            <Setter Property="Background" Value="#172130" />
        </Style>
        <Style Selector="Border.group-container-background.selected.hover">
            <Setter Property="Background" Value="#1E2A39" />
        </Style>
        <Style Selector="Border.group-container-background.pressed">
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Border.group-header-shell">
            <Setter Property="Background" Value="#182230" />
        </Style>
        <Style Selector="Border.group-header-shell.selected">
            <Setter Property="Background" Value="#202D3B" />
        </Style>
        <Style Selector="Border.group-header-shell.hover">
            <Setter Property="Background" Value="#223142" />
        </Style>
        <Style Selector="Border.group-header-shell.selected.hover">
            <Setter Property="Background" Value="#29394A" />
        </Style>
        <Style Selector="Border.group-header-shell.pressed">
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Border.group-container-border">
            <Setter Property="Opacity" Value="0.58" />
        </Style>
        <Style Selector="Border.group-container-border.selected">
            <Setter Property="Opacity" Value="0.84" />
        </Style>
        <Style Selector="Border.group-container-border.hover">
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="Border.group-container-border.selected.hover">
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Border.group-container-border.pressed">
            <Setter Property="Opacity" Value="0.96" />
        </Style>
        <!-- Planned and Pending share one neutral queued/preview treatment, while Cancelled, Disabled, and Skipped share
             a more muted inactive treatment. -->
        <Style Selector="Border.group-container-border.pending, Border.group-container-border.planned">
            <Setter Property="BorderBrush" Value="#98A9B8" />
        </Style>
        <Style Selector="Border.group-container-border.cancelled, Border.group-container-border.skipped, Border.group-container-border.disabled">
            <Setter Property="BorderBrush" Value="#69717A" />
        </Style>
        <Style Selector="Border.group-container-border.running">
            <Setter Property="BorderBrush" Value="#63A8FF" />
        </Style>
        <Style Selector="Border.group-container-border.completed">
            <Setter Property="BorderBrush" Value="#7BE37B" />
        </Style>
        <Style Selector="Border.group-container-border.failed">
            <Setter Property="BorderBrush" Value="#FF5C5C" />
        </Style>
    </UserControl.Styles>
    <!-- This control owns the full visual structure of one group node so canvas code only decides placement and z-order. -->
    <Grid Width="{Binding GroupWidth, RelativeSource={RelativeSource AncestorType=controls:ExecutionGroupContainer}}"
          Height="{Binding GroupHeight, RelativeSource={RelativeSource AncestorType=controls:ExecutionGroupContainer}}"
          ClipToBounds="False">
        <!-- The outer frame carries the status-tinted border around the full group, including the header region. -->
        <Border x:Name="ContainerBackgroundShell"
                Classes="group-container-background"
                CornerRadius="12" />
        <Border x:Name="ContainerBorderChrome"
                Classes="group-container-border"
                BorderThickness="{Binding ContainerBorderThickness}"
                CornerRadius="12"
                IsHitTestVisible="False" />

        <!-- The header sits inset inside the outer frame so the full group border remains visible around it. -->
        <Border x:Name="ClickSurface"
                Classes="graph-interactive"
                Background="Transparent"
                ClipToBounds="False"
                CornerRadius="10,10,0,0"
                Margin="{Binding ContainerBorderThickness}"
                Height="{Binding HeaderHeight, RelativeSource={RelativeSource AncestorType=controls:ExecutionGroupContainer}}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Border x:Name="HeaderShell"
                    Classes="group-header-shell"
                    ClipToBounds="False"
                    CornerRadius="10,10,0,0">
                <!-- Center the title/status row within the header so the compact status indicator shares the same
                     visual baseline as the title. -->
                <Grid ColumnDefinitions="Auto,Auto,*"
                      Margin="14,10,14,10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F3F6F9"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <controls:StatusIndicator Grid.Column="1"
                                              Margin="12,0,0,0"
                                              Status="{Binding Status}"
                                              ShowLabel="True"
                                              DotSize="6"
                                              LabelFontSize="11"
                                              VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Border>

        <!-- Keep the existing compact tooltip treatment, but declare the visual tree in XAML with the rest of the node. -->
        <ToolTip.Tip>
            <ToolTip Background="#12171D"
                     BorderBrush="#33414F"
                     BorderThickness="1"
                     Padding="10,8"
                     MaxWidth="320"
                     IsOpen="False">
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="#D5DEE7"
                           FontSize="12"
                           LineHeight="16" />
            </ToolTip>
        </ToolTip.Tip>
    </Grid>
</UserControl>
