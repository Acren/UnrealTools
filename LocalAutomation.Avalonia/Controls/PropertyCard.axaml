<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pgc="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Controls.PropertyCard"
             x:DataType="controls:PropertyCard">
    <!-- Keep settings and operation options on the same visual/layout path by sharing one card shell around the
         standard property grid. -->
    <Border Classes="card" Padding="10,8">
        <Grid RowDefinitions="Auto,*">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:PropertyCard}}"
                       Classes="panel-title" />
            <pgc:PropertyGrid Grid.Row="1"
                              Margin="0,10,0,0"
                              DataContext="{Binding PropertyGridTarget, RelativeSource={RelativeSource AncestorType=controls:PropertyCard}}"
                              IsQuickFilterVisible="False"
                              IsCategoryVisible="False"
                              IsHeaderVisible="False"
                              IsTitleVisible="False" />
        </Grid>
    </Border>
</UserControl>
