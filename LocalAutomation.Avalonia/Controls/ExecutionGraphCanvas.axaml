<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             x:Class="LocalAutomation.Avalonia.Controls.ExecutionGraphCanvas"
             x:DataType="vm:ExecutionGraphViewModel"
             UseLayoutRounding="True">
    <Grid>
        <!-- Keep the visible graph surface unchanged until one hidden attached measurement pass has produced the final
             node widths and relaid out the graph. -->
        <Border x:Name="ViewportHost"
                Background="Transparent"
                UseLayoutRounding="True"
                ClipToBounds="False"
                PointerPressed="ViewportHost_PointerPressed"
                PointerMoved="ViewportHost_PointerMoved"
                PointerReleased="ViewportHost_PointerReleased"
                PointerCaptureLost="ViewportHost_PointerCaptureLost"
                PointerWheelChanged="ViewportHost_PointerWheelChanged">
            <Border x:Name="GraphContentRoot"
                    Width="{Binding CanvasWidth}"
                    Height="{Binding CanvasHeight}"
                    UseLayoutRounding="True"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    RenderTransformOrigin="0,0">
                <!-- Separate retained layers keep z-order structural instead of relying on manual child-index juggling
                     inside one flat canvas. Groups stay behind edges, and edges stay behind task cards. -->
                <Grid Width="{Binding CanvasWidth}"
                      Height="{Binding CanvasHeight}"
                      UseLayoutRounding="True">
                    <Canvas x:Name="GroupCanvas"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            UseLayoutRounding="True"
                            IsHitTestVisible="True" />
                    <Canvas x:Name="EdgeCanvas"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            UseLayoutRounding="True"
                            IsHitTestVisible="True" />
                    <Canvas x:Name="TaskCanvas"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            UseLayoutRounding="True"
                            IsHitTestVisible="True" />
                </Grid>
            </Border>
        </Border>

        <!-- Keep the measurement host attached to the visual tree so Avalonia can fully realize composite control widths
             while remaining invisible and non-interactive to the user. -->
        <Canvas x:Name="MeasurementCanvas"
                Width="0"
                Height="0"
                IsHitTestVisible="False"
                Opacity="0"
                ClipToBounds="True" />
    </Grid>
</UserControl>
