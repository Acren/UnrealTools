<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             x:Class="LocalAutomation.Avalonia.Controls.ExecutionGraphCanvas"
             x:DataType="vm:ExecutionGraphViewModel"
             UseLayoutRounding="True">
    <Grid>
        <!-- The visible graph surface is now the single width source. Node controls report intrinsic width changes from
             their real content, and the canvas batches relayout from those live width signals. -->
        <Border x:Name="ViewportHost"
                Background="Transparent"
                UseLayoutRounding="True"
                ClipToBounds="False"
                PointerPressed="ViewportHost_PointerPressed"
                PointerMoved="ViewportHost_PointerMoved"
                PointerReleased="ViewportHost_PointerReleased"
                PointerCaptureLost="ViewportHost_PointerCaptureLost"
                PointerWheelChanged="ViewportHost_PointerWheelChanged">
            <Border x:Name="GraphContentRoot"
                    Width="{Binding CanvasWidth}"
                    Height="{Binding CanvasHeight}"
                    UseLayoutRounding="True"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    RenderTransformOrigin="0,0">
                <!-- Keep task cards in their own top layer while groups and edges share one structural canvas whose child
                     ZIndex values can interleave whole edges between unrelated group containers. -->
                <Grid Width="{Binding CanvasWidth}"
                      Height="{Binding CanvasHeight}"
                      UseLayoutRounding="True">
                    <Canvas x:Name="StructureCanvas"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            UseLayoutRounding="True"
                            IsHitTestVisible="True" />
                    <Canvas x:Name="TaskCanvas"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            UseLayoutRounding="True"
                            IsHitTestVisible="True" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
