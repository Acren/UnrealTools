<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Controls.ExecutionTaskCard"
             x:CompileBindings="False"
             x:Name="Root">
    <UserControl.Styles>
        <!-- Task card styling is driven entirely by semantic classes so state owns hue while hover and selection only
             adjust emphasis. Hover uses a lighter fill so cards feel more obviously interactive. -->
        <Style Selector="controls|AnimatedConicBorder.task-card-animated-border">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsVisible" Value="False" />
            <!-- Keep the animated border colors in styling so callers can replace the whole conic highlight treatment
                 without threading individual color properties through the control API. -->
            <Setter Property="AnimationBrush">
                <ConicGradientBrush Center="50%,50%">
                    <GradientStop Color="#4563A8FF" Offset="0.00" />
                    <GradientStop Color="#4563A8FF" Offset="0.20" />
                    <GradientStop Color="#79BEFF" Offset="0.24" />
                    <GradientStop Color="#EAF8FF" Offset="0.27" />
                    <GradientStop Color="#79BEFF" Offset="0.30" />
                    <GradientStop Color="#4563A8FF" Offset="0.34" />
                    <GradientStop Color="#4563A8FF" Offset="0.70" />
                    <GradientStop Color="#79BEFF" Offset="0.74" />
                    <GradientStop Color="#EAF8FF" Offset="0.77" />
                    <GradientStop Color="#79BEFF" Offset="0.80" />
                    <GradientStop Color="#4563A8FF" Offset="0.84" />
                    <GradientStop Color="#4563A8FF" Offset="1.00" />
                </ConicGradientBrush>
            </Setter>
        </Style>
        <Style Selector="controls|AnimatedConicBorder.task-card-animated-border.running">
            <!-- The animated border sits on top of the base stroke and only appears for the active status treatment. -->
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!-- The outer shell owns overall card opacity so status dimming affects the full tile consistently while the
             inner layers stay focused on their own visual roles. -->
        <Style Selector="Border.task-card-shell">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.task-card-shell.pending, Border.task-card-shell.planned, Border.task-card-shell.cancelled, Border.task-card-shell.skipped">
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Border.task-card-shell.interrupted, Border.task-card-shell.disabled">
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <!-- Most interaction states now fall back to the shared shell rules so status styling stays compact. Only the
             inactive hover override remains specialized so disabled cards do not brighten all the way back to active
             card strength. -->
        <Style Selector="Border.task-card-shell.hover">
            <Setter Property="Opacity" Value="0.97" />
        </Style>
        <Style Selector="Border.task-card-shell.interrupted.hover, Border.task-card-shell.disabled.hover">
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Border.task-card-shell.selected">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.task-card-shell.pressed">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Border.task-card-background">
            <Setter Property="Background" Value="#1D2835" />
        </Style>
        <Style Selector="Border.task-card-background.selected">
            <Setter Property="Background" Value="#263342" />
        </Style>
        <Style Selector="Border.task-card-background.hover">
            <Setter Property="Background" Value="#253344" />
        </Style>
        <Style Selector="Border.task-card-background.selected.hover">
            <Setter Property="Background" Value="#2C3C4E" />
        </Style>
        <!-- The background layer only owns fill colors so status and interaction changes can retint the surface without
             independently changing card opacity. -->
        <Style Selector="Border.task-card-background.pending, Border.task-card-background.planned, Border.task-card-background.cancelled, Border.task-card-background.skipped">
            <Setter Property="Background" Value="#1C2733" />
        </Style>
        <Style Selector="Border.task-card-background.interrupted, Border.task-card-background.disabled">
            <Setter Property="Background" Value="#171F29" />
        </Style>
        <Style Selector="Border.task-card-border">
            <Setter Property="Opacity" Value="0.78" />
        </Style>
        <Style Selector="Border.task-card-border.selected">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.task-card-border.hover">
            <Setter Property="Opacity" Value="0.96" />
        </Style>
        <Style Selector="Border.task-card-border.selected.hover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.task-card-border.pressed">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!-- Planned, Pending, Cancelled, and Skipped all use the same neutral queued treatment. Awaiting lock gets a
             slightly more active intermediate treatment, while Interrupted and Disabled keep the more muted inactive
             treatment. -->
        <Style Selector="Border.task-card-border.pending, Border.task-card-border.planned, Border.task-card-border.cancelled, Border.task-card-border.skipped">
            <Setter Property="BorderBrush" Value="#7F8C97" />
        </Style>
        <Style Selector="Border.task-card-border.awaiting-lock">
            <Setter Property="BorderBrush" Value="#5C8EA8C7" />
        </Style>
        <Style Selector="Border.task-card-border.interrupted, Border.task-card-border.disabled">
            <Setter Property="BorderBrush" Value="#59616A" />
        </Style>
        <Style Selector="Border.task-card-border.running">
            <!-- Keep a faint continuous stroke under the animated highlights so the card still reads as one border. -->
            <Setter Property="BorderBrush" Value="#4563A8FF" />
        </Style>
        <Style Selector="Border.task-card-border.completed">
            <Setter Property="BorderBrush" Value="#7BE37B" />
        </Style>
        <Style Selector="Border.task-card-border.failed">
            <Setter Property="BorderBrush" Value="#FF5C5C" />
        </Style>
    </UserControl.Styles>
    <!-- This control owns the full task-card markup so graph canvas code no longer constructs the inner visual tree. -->
    <Grid MinWidth="156"
          Height="{Binding CardHeight, RelativeSource={RelativeSource AncestorType=controls:ExecutionTaskCard}}"
          ClipToBounds="False">
        <Border x:Name="ClickSurface"
                Classes="graph-interactive task-card-shell"
                Background="Transparent"
                CornerRadius="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <Grid>
                    <Border x:Name="CardBackgroundShell"
                            Classes="task-card-background"
                            CornerRadius="8" />
                    <Border x:Name="CardBorderChrome"
                            Classes="task-card-border"
                            BorderThickness="{Binding CardBorderThickness}"
                            CornerRadius="8"
                            IsHitTestVisible="False" />
                    <!-- Keep the animated border as a real Border stroke so rounded corners and stroke thickness stay
                         consistent while the conic brush rotates two opposing highlights around the card. -->
                    <controls:AnimatedConicBorder x:Name="AnimatedBorderChrome"
                                                  Classes="task-card-animated-border"
                                                  BorderThickness="{Binding CardBorderThickness}"
                                                  CornerRadius="8"
                                                  IsHitTestVisible="False" />
                    <!-- Center the title/status block within the card so shorter cards do not feel top-weighted. -->
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="6"
                          Margin="18,10,18,10"
                          VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                               Foreground="#F2F5F8"
                               MaxHeight="40"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                        <controls:StatusIndicator Grid.Row="1"
                                                  Status="{Binding DisplayStatus}"
                                                  ShowLabel="True"
                                                  DotSize="6"
                                                LabelFontSize="11"
                                               VerticalAlignment="Center" />
                        <controls:ExecutionMetricsStrip Grid.Row="2"
                                                        Metrics="{Binding Metrics}"
                                                        VerticalAlignment="Center" />
                  </Grid>
            </Grid>
        </Border>

        <!-- Keep the tooltip markup declarative with the task-card visuals instead of constructing it in canvas code. -->
        <ToolTip.Tip>
            <ToolTip Background="#12171D"
                     BorderBrush="#33414F"
                     BorderThickness="1"
                     Padding="10,8"
                     MaxWidth="320"
                     IsOpen="False">
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="#D5DEE7"
                           FontSize="12"
                           LineHeight="16" />
            </ToolTip>
        </ToolTip.Tip>
    </Grid>
</UserControl>
