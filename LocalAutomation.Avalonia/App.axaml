<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pgc="clr-namespace:Avalonia.PropertyGrid.Controls;assembly=Avalonia.PropertyGrid"
             xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="LocalAutomation.Avalonia.App">
    <!-- Centralized graphite tokens let the shell mirror the mockup without scattering hard-coded colors. -->
    <Application.Resources>
        <FontFamily x:Key="AppUiFont">avares://LocalAutomation.Avalonia/Assets/Fonts#Inter</FontFamily>
        <Color x:Key="GraphiteBackgroundColor">#16181B</Color>
        <Color x:Key="GraphitePanelColor">#1B1E22</Color>
        <Color x:Key="GraphiteCardColor">#22262B</Color>
        <Color x:Key="GraphiteDropdownColor">#1A1E22</Color>
        <Color x:Key="GraphiteDropdownHoverColor">#20262C</Color>
        <Color x:Key="GraphiteDropdownSelectedColor">#28313A</Color>
        <Color x:Key="GraphiteDropdownSelectedBorderColor">#6B7B88</Color>
        <Color x:Key="GraphiteInputColor">#14171A</Color>
        <Color x:Key="GraphiteTerminalColor">#101215</Color>
        <Color x:Key="GraphiteLineColor">#2D333A</Color>
        <Color x:Key="GraphiteLineStrongColor">#434C56</Color>
        <Color x:Key="GraphiteLineSubtleColor">#252A30</Color>
        <Color x:Key="GraphiteTextColor">#EDF0F3</Color>
        <Color x:Key="GraphiteTextSoftColor">#C2C8CF</Color>
        <Color x:Key="GraphiteTextMutedColor">#89919A</Color>
        <Color x:Key="GraphiteTextInverseColor">#121417</Color>
        <Color x:Key="GraphiteAccentColor">#AEB9C5</Color>
        <Color x:Key="GraphiteAccentHoverColor">#C8D1DA</Color>
        <Color x:Key="GraphiteActiveBorderColor">#75AEB9C5</Color>
        <Color x:Key="GraphiteActiveBackgroundColor">#12AEB9C5</Color>
        <Color x:Key="GraphiteDangerColor">#EF8680</Color>
        <Color x:Key="GraphiteDangerBackgroundColor">#24EF8680</Color>
        <Color x:Key="GraphiteWarningColor">#F1D479</Color>
        <Color x:Key="GraphiteWarningBackgroundColor">#20F1D479</Color>
        <!-- Execution-status palette tokens stay semantic and control-agnostic. Individual controls own any extra
             emphasis through opacity, glow, and stroke thickness instead of requiring separate per-control resources. -->
        <Color x:Key="ExecutionStatusQueuedColor">#7F8C97</Color>
        <Color x:Key="ExecutionStatusAwaitingDependencyColor">#C9A86A</Color>
        <Color x:Key="ExecutionStatusAwaitingLockColor">#9A8FF0</Color>
        <Color x:Key="ExecutionStatusInactiveColor">#59616A</Color>
        <Color x:Key="ExecutionStatusRunningColor">#63A8FF</Color>
        <Color x:Key="ExecutionStatusCompletedColor">#7BE37B</Color>
        <Color x:Key="ExecutionStatusFailedColor">#FF5C5C</Color>

        <SolidColorBrush x:Key="GraphiteBackgroundBrush" Color="{StaticResource GraphiteBackgroundColor}" />
        <SolidColorBrush x:Key="GraphitePanelBrush" Color="{StaticResource GraphitePanelColor}" />
        <SolidColorBrush x:Key="GraphiteCardBrush" Color="{StaticResource GraphiteCardColor}" />
        <SolidColorBrush x:Key="GraphiteDropdownBrush" Color="{StaticResource GraphiteDropdownColor}" />
        <SolidColorBrush x:Key="GraphiteDropdownHoverBrush" Color="{StaticResource GraphiteDropdownHoverColor}" />
        <SolidColorBrush x:Key="GraphiteDropdownSelectedBrush" Color="{StaticResource GraphiteDropdownSelectedColor}" />
        <SolidColorBrush x:Key="GraphiteDropdownSelectedBorderBrush" Color="{StaticResource GraphiteDropdownSelectedBorderColor}" />
        <SolidColorBrush x:Key="GraphiteInputBrush" Color="{StaticResource GraphiteInputColor}" />
        <SolidColorBrush x:Key="GraphiteTerminalBrush" Color="{StaticResource GraphiteTerminalColor}" />
        <SolidColorBrush x:Key="GraphiteLineBrush" Color="{StaticResource GraphiteLineColor}" />
        <SolidColorBrush x:Key="GraphiteLineStrongBrush" Color="{StaticResource GraphiteLineStrongColor}" />
        <SolidColorBrush x:Key="GraphiteLineSubtleBrush" Color="{StaticResource GraphiteLineSubtleColor}" />
        <SolidColorBrush x:Key="GraphiteTextBrush" Color="{StaticResource GraphiteTextColor}" />
        <SolidColorBrush x:Key="GraphiteTextSoftBrush" Color="{StaticResource GraphiteTextSoftColor}" />
        <SolidColorBrush x:Key="GraphiteTextMutedBrush" Color="{StaticResource GraphiteTextMutedColor}" />
        <SolidColorBrush x:Key="GraphiteTextInverseBrush" Color="{StaticResource GraphiteTextInverseColor}" />
        <SolidColorBrush x:Key="GraphiteAccentBrush" Color="{StaticResource GraphiteAccentColor}" />
        <SolidColorBrush x:Key="GraphiteAccentHoverBrush" Color="{StaticResource GraphiteAccentHoverColor}" />
        <SolidColorBrush x:Key="GraphiteActiveBorderBrush" Color="{StaticResource GraphiteActiveBorderColor}" />
        <SolidColorBrush x:Key="GraphiteActiveBackgroundBrush" Color="{StaticResource GraphiteActiveBackgroundColor}" />
        <SolidColorBrush x:Key="GraphiteDangerBrush" Color="{StaticResource GraphiteDangerColor}" />
        <SolidColorBrush x:Key="GraphiteDangerBackgroundBrush" Color="{StaticResource GraphiteDangerBackgroundColor}" />
        <SolidColorBrush x:Key="GraphiteWarningBrush" Color="{StaticResource GraphiteWarningColor}" />
        <SolidColorBrush x:Key="GraphiteWarningBackgroundBrush" Color="{StaticResource GraphiteWarningBackgroundColor}" />
        <SolidColorBrush x:Key="ExecutionStatusQueuedBrush" Color="{StaticResource ExecutionStatusQueuedColor}" />
        <SolidColorBrush x:Key="ExecutionStatusAwaitingDependencyBrush" Color="{StaticResource ExecutionStatusAwaitingDependencyColor}" />
        <SolidColorBrush x:Key="ExecutionStatusAwaitingLockBrush" Color="{StaticResource ExecutionStatusAwaitingLockColor}" />
        <SolidColorBrush x:Key="ExecutionStatusInactiveBrush" Color="{StaticResource ExecutionStatusInactiveColor}" />
        <SolidColorBrush x:Key="ExecutionStatusRunningBrush" Color="{StaticResource ExecutionStatusRunningColor}" />
        <SolidColorBrush x:Key="ExecutionStatusCompletedBrush" Color="{StaticResource ExecutionStatusCompletedColor}" />
        <SolidColorBrush x:Key="ExecutionStatusFailedBrush" Color="{StaticResource ExecutionStatusFailedColor}" />
    </Application.Resources>
    <Application.Styles>
        <themes:FluentTheme>
            <!-- Fluent still owns many list/popup visuals internally, so the stable way to get dropdowns aligned with
                 our graphite-blue direction is to provide a custom dark palette rather than fight each template part
                 individually. -->
            <themes:FluentTheme.Palettes>
                <themes:ColorPaletteResources x:Key="Dark"
                                              Accent="{StaticResource GraphiteAccentColor}"
                                              RegionColor="{StaticResource GraphitePanelColor}"
                                              ErrorText="{StaticResource GraphiteDangerColor}"
                                              BaseHigh="{StaticResource GraphiteTextColor}"
                                              BaseMedium="{StaticResource GraphiteTextSoftColor}"
                                              BaseMediumLow="{StaticResource GraphiteTextMutedColor}"
                                              ChromeHigh="{StaticResource GraphiteLineStrongColor}"
                                              ChromeMedium="{StaticResource GraphiteLineColor}"
                                              ChromeMediumLow="{StaticResource GraphiteLineSubtleColor}"
                                              ChromeLow="{StaticResource GraphiteInputColor}"
                                              ListLow="{StaticResource GraphiteDropdownColor}"
                                              ListMedium="{StaticResource GraphiteDropdownHoverColor}" />
            </themes:FluentTheme.Palettes>
        </themes:FluentTheme>

        <!-- The shell defaults everything to the graphite palette so the window reads like a dense desktop tool. -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource GraphiteBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppUiFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Shared slab styles keep panels and cards visually consistent across the shell. -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource GraphitePanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource GraphiteCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Border.inset">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Border.terminal-shell">
            <Setter Property="Background" Value="{DynamicResource GraphiteTerminalBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Border.pill">
            <Setter Property="Background" Value="{DynamicResource GraphiteCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Border.pill.warning-accent">
            <Setter Property="BorderBrush" Value="#55F1D479" />
        </Style>
        <Style Selector="Border.pill.error-accent">
            <Setter Property="BorderBrush" Value="#66EF8680" />
        </Style>
        <Style Selector="Border.execution-node-card">
            <Setter Property="Background" Value="#1A2430" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BoxShadow" Value="0 10 20 0 #20000000" />
        </Style>
        <Style Selector="Border.execution-node-card.group">
            <Setter Property="Background" Value="#141B25" />
            <Setter Property="Opacity" Value="0.96" />
        </Style>
        <Style Selector="Border.execution-node-card.selected">
            <Setter Property="BoxShadow" Value="0 0 0 1 #6AA7C2D8, 0 14 28 0 #26000000" />
        </Style>
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="GridSplitter.resize-handle-vertical">
            <Setter Property="Background" Value="{DynamicResource GraphiteLineSubtleBrush}" />
        </Style>
        <Style Selector="GridSplitter.resize-handle-horizontal">
            <Setter Property="Background" Value="{DynamicResource GraphiteLineSubtleBrush}" />
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
        </Style>
        <Style Selector="GridSplitter:pressed">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
        </Style>
        <Style Selector="GridSplitter.resize-handle-vertical:pointerover, GridSplitter.resize-handle-horizontal:pointerover">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBorderBrush}" />
        </Style>
        <Style Selector="GridSplitter.resize-handle-vertical:pressed, GridSplitter.resize-handle-horizontal:pressed">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBorderBrush}" />
        </Style>

        <!-- Typography styles recreate the uppercase graphite chrome from the reference. -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
        </Style>
        <Style Selector="TextBlock.metric-pill-text">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="10" />
            <!-- Monospace caps sit a touch high in these compact pills, so add a tiny downward nudge. -->
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
        <Style Selector="TextBlock.warning-accent">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteWarningBrush}" />
        </Style>
        <Style Selector="TextBlock.error-accent">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteDangerBrush}" />
        </Style>
        <Style Selector="TextBlock.soft">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <Style Selector="TextBlock.detail-label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="TextBlock.status-danger">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteDangerBrush}" />
        </Style>

        <!-- Buttons trade Fluent glow for flat, deliberate graphite controls. -->
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Button.small">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource GraphiteAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextInverseBrush}" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource GraphiteAccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextInverseBrush}" />
        </Style>
        <Style Selector="Button.subtle">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="Button.subtle:pointerover">
            <Setter Property="Background" Value="{DynamicResource GraphiteCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <!-- Close chips share one touch target so tab and target-row affordances can sit on the same visual rail. -->
        <Style Selector="Button.close-chip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <!-- The shared close-chip icon uses vector strokes bound to the button foreground so hover and
                             active color changes stay consistent anywhere the chip is reused. -->
                        <Grid Width="8" Height="8">
                            <Path Data="M 1,1 L 7,7"
                                  StrokeThickness="1.4"
                                  Stroke="{Binding $parent[Button].Foreground}" />
                            <Path Data="M 7,1 L 1,7"
                                  StrokeThickness="1.4"
                                  Stroke="{Binding $parent[Button].Foreground}" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.close-chip:pointerover">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteDangerBrush}" />
            <Setter Property="BorderBrush" Value="#66EF8680" />
        </Style>
        <Style Selector="Button.tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="Button.tab /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="17,6,17,6" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <!-- Closable tabs reserve the close-chip lane through padding so the content tree can stay shared. -->
        <Style Selector="Button.tab.closable /template/ ContentPresenter">
            <Setter Property="Padding" Value="16,6,40,6" />
        </Style>
        <Style Selector="Button.tab:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="Button.tab.active">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="Button.tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="Button.tab.active:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="Button.tab.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="Button.tab TextBlock.panel-title">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Opacity" Value="0.88" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tab:pointerover TextBlock.panel-title">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="Opacity" Value="0.96" />
        </Style>
        <Style Selector="Button.tab.active TextBlock.panel-title">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="TextBlock.tab-subtitle">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tab:pointerover TextBlock.tab-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.tab.active TextBlock.tab-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style Selector="Border.runtime-status-dot">
            <Setter Property="Background" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter>
        </Style>
        <Style Selector="Border.runtime-status-dot.running">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusRunningBrush}" />
            <Setter Property="BoxShadow" Value="0 0 5 0 #5563A8FF" />
            <!-- Running tasks pulse through brightness only so active work stands out without changing size or glow radius. -->
            <Style.Animations>
                <Animation Duration="0:0:0.7"
                           IterationCount="INFINITE"
                           PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.4" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.runtime-status-dot.succeeded">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusCompletedBrush}" />
            <Setter Property="BoxShadow" Value="0 0 5 0 #557BE37B" />
        </Style>
        <Style Selector="Border.runtime-status-dot.failed">
            <Setter Property="Background" Value="{DynamicResource ExecutionStatusFailedBrush}" />
            <Setter Property="BoxShadow" Value="0 0 5 0 #55FF7575" />
        </Style>

        <!-- Execution edges share the same semantic status classes as cards and indicators so graph tinting stays in
             XAML even though the edge geometry itself is still created imperatively in the canvas control. Inactive
             dependency states intentionally stay more subdued so disabled and otherwise non-runnable branches recede
             behind active work. -->
        <Style Selector="Path.execution-edge">
            <Setter Property="Stroke" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Opacity" Value="0.68" />
            <Setter Property="StrokeThickness" Value="2" />
        </Style>
        <Style Selector="Path.execution-edge.pending, Path.execution-edge.planned">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusQueuedBrush}" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <!-- Dependency edges should inherit the same blocker/contender distinction as the target node so graph flow
             communicates whether work is waiting on an external prerequisite or on local lock contention. -->
        <Style Selector="Path.execution-edge.awaiting-dependency">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusAwaitingDependencyBrush}" />
            <Setter Property="Opacity" Value="0.62" />
        </Style>
        <Style Selector="Path.execution-edge.awaiting-lock">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusAwaitingLockBrush}" />
            <Setter Property="Opacity" Value="0.66" />
        </Style>
        <Style Selector="Path.execution-edge.cancelled, Path.execution-edge.interrupted, Path.execution-edge.disabled, Path.execution-edge.skipped">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusInactiveBrush}" />
            <Setter Property="Opacity" Value="0.34" />
        </Style>
        <Style Selector="Path.execution-edge.running">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusRunningBrush}" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Path.execution-edge.completed">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusCompletedBrush}" />
            <Setter Property="Opacity" Value="0.76" />
        </Style>
        <Style Selector="Path.execution-edge.failed">
            <Setter Property="Stroke" Value="{DynamicResource ExecutionStatusFailedBrush}" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- Hover only boosts emphasis and thickness so the existing semantic hue still communicates status. -->
        <Style Selector="Path.execution-edge.hover">
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="StrokeThickness" Value="3" />
        </Style>
        <!-- Inputs use the same compact mechanical treatment as the mockup. -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="NumericUpDown:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="DatePicker:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="SelectableTextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Scrollbars and popup lists get the same hard-edged graphite treatment as the main shell. -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource GraphiteLineStrongBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="MinHeight" Value="10" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource GraphiteAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="FlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ComboBox /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="ComboBox:not(:selected) /template/ ContentControl#PlaceholderTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ ToggleButton">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ComboBox /template/ ToggleButton:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="ComboBox.target-picker">
            <Setter Property="MinHeight" Value="58" />
        </Style>
        <Style Selector="ComboBox.target-picker:pointerover /template/ ToggleButton">
            <Setter Property="Background" Value="{DynamicResource GraphiteCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="ComboBox.target-picker:focus /template/ ToggleButton">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <!-- Override the Fluent disabled brushes at the same template parts Fluent uses so the intentionally disabled
             operation picker still reads like one of our graphite inputs instead of falling back to a washed-out gray. -->
        <Style Selector="ComboBox.operation-picker:disabled /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
        </Style>
        <Style Selector="ComboBox.operation-picker:disabled /template/ ContentControl#ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="ComboBox.operation-picker:disabled /template/ TextBlock#PlaceholderTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="ComboBox.operation-picker:disabled /template/ PathIcon#DropDownGlyph">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ PopupRoot Border">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="ComboBox /template/ PopupRoot">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ PopupRoot ScrollViewer">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <!-- The popup surface comes from the Fluent palette; we only nudge row states here so they stay close to the
             default Fluent behavior while shifting toward the app's cooler graphite-blue tones. Keeping a constant
             border thickness prevents item wobble when hover/selection changes. -->
        <Style Selector="ComboBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GraphiteDropdownSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteDropdownSelectedBorderBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover TextBlock, ComboBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="ComboBox.target-picker ComboBoxItem">
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="ComboBox.target-picker ComboBoxItem:last-child">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="12,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Target-row remove buttons reuse the shared close-chip baseline and only swap in a slightly stronger
             outlined hover/pressed treatment so the affordance reads clearly inside the picker row. -->
        <Style Selector="Button.close-chip.target-remove:pointerover">
            <Setter Property="Background" Value="#30FFFFFF" />
            <Setter Property="BorderBrush" Value="#48FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="Button.close-chip.target-remove:pressed">
            <Setter Property="Background" Value="#44FFFFFF" />
            <Setter Property="BorderBrush" Value="#58FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="AutoCompleteBox /template/ TextBox">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>

        <!-- The target list uses the selection border rather than Fluent's filled highlight. -->
        <Style Selector="ListBox.targets-list">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.targets-list ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.targets-list ListBoxItem:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="ListBox.targets-list ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource GraphiteActiveBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteActiveBorderBrush}" />
        </Style>
        <Style Selector="ListBox.targets-list ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Property-grid specific styles pull the embedded editor controls toward the same compact graphite language. -->
        <Style Selector="pgc|PropertyGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="pgc|PropertyGrid Border">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
        </Style>
        <Style Selector="pgc|PropertyGrid TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="pgc|PropertyGrid Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="pgc|PropertyGrid CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="pgc|PropertyGrid ToggleButton">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="pgc|PropertyGrid ToggleButton:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineStrongBrush}" />
        </Style>
        <Style Selector="pgc|PropertyGrid Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextSoftBrush}" />
        </Style>
        <Style Selector="pgc|PropertyGrid Expander /template/ ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextMutedBrush}" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="pgc|PropertyGrid Expander /template/ ToggleButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
        <Style Selector="pgc|PropertyGrid ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="pgc|PropertyGrid TextBox, pgc|PropertyGrid ComboBox, pgc|PropertyGrid NumericUpDown, pgc|PropertyGrid DatePicker">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style Selector="pgc|PropertyGrid TextBox:focus, pgc|PropertyGrid ComboBox:focus, pgc|PropertyGrid NumericUpDown:focus, pgc|PropertyGrid DatePicker:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource GraphiteAccentBrush}" />
        </Style>
        <Style Selector="pgc|ButtonEdit, pgc|ListEdit, pgc|CheckedListEdit, pgc|CheckedMask">
            <Setter Property="Background" Value="{DynamicResource GraphiteInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GraphiteTextBrush}" />
        </Style>
    </Application.Styles>
</Application>
