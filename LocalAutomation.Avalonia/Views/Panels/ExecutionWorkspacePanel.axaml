<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             xmlns:conv="clr-namespace:LocalAutomation.Avalonia.Converters"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             x:Class="LocalAutomation.Avalonia.Views.Panels.ExecutionWorkspacePanel"
             x:DataType="vm:ExecutionWorkspaceViewModel">
    <UserControl.Resources>
        <conv:UppercaseTextConverter x:Key="UppercaseTextConverter" />
    </UserControl.Resources>
    <!-- This panel isolates the execution workspace tabs, graph preview canvas, scoped logs, and runtime cancellation. -->
    <Border Classes="panel">
        <Grid RowDefinitions="Auto,*" MinHeight="0">
            <!-- Keep the tab strip visually integrated with the panel edge instead of floating inside extra header padding. -->
            <Border Padding="0" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding RuntimeTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuntimeWorkspaceTabViewModel">
                                    <Grid MinHeight="34">
                                        <Button Classes="tab"
                                                Classes.active="{Binding IsSelected}"
                                                Classes.app-log="{Binding IsApplicationLog}"
                                                Classes.plan-preview="{Binding IsPlanPreview}"
                                                Classes.closable="{Binding CanClose}"
                                                PointerPressed="RuntimeTab_PointerPressed"
                                                Click="RuntimeTab_Click">
                                            <Button.Content>
                                                <!-- One shared tab-content layout keeps the optional status dot and
                                                     subtitle behavior in a single place for both task tabs and the
                                                     pinned application log tab. -->
                                                <Grid MinHeight="34">
                                                    <!-- Compact tabs such as APP LOG and PLAN use a title-only layout so
                                                         their labels center naturally from the same shared template. -->
                                                    <TextBlock Text="{Binding Title, Converter={StaticResource UppercaseTextConverter}}"
                                                               Classes="panel-title"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding UsesCompactStripLayout}" />

                                                    <!-- Rich execution tabs keep the status lane and optional subtitle in
                                                         the full strip layout. -->
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="0"
                                                          IsVisible="{Binding UsesDetailedStripLayout}">
                                                        <!-- The marker lane owns its own trailing gap so tabs without a status
                                                             dot do not keep a phantom left offset. -->
                                                        <controls:StatusIndicator Grid.Column="0"
                                                                                  Width="12"
                                                                                  Margin="0,0,8,0"
                                                                                  VerticalAlignment="Center"
                                                                                  IsVisible="{Binding ShowsStatusMarker}"
                                                                                  ShowLabel="False"
                                                                                  DotSize="6"
                                                                                  Status="{Binding SessionStatusForIndicator}" />
                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Center"
                                                                    Spacing="0">
                                                            <TextBlock Text="{Binding Title, Converter={StaticResource UppercaseTextConverter}}"
                                                                       Classes="panel-title" />
                                                            <!-- Subtitle rows collapse cleanly for tabs that stay on one
                                                                 line even while sharing the richer execution-tab layout. -->
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                       IsVisible="{Binding ShowsSubtitle}"
                                                                       Classes="tab-subtitle" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <!-- The close affordance uses the same right-edge inset as the target picker. -->
                                        <Button Classes="close-chip"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding CanClose}"
                                                Click="CloseRuntimeTab_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Grid.Column="1"
                            Padding="10,8"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <!-- Selected-task diagnostics stay beside terminate so the active task summary is readable
                             without stealing space from the tab strip itself. -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSelectedRuntimeMetrics}">
                                <controls:ExecutionMetricsStrip Metrics="{Binding SelectedRuntimeMetrics}" />
                            </StackPanel>
                            <Button Classes="danger small"
                                    Content="Terminate"
                                    Click="Terminate_Click"
                                    IsEnabled="{Binding IsRunning}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- One shared graph host and one shared log host adapt between split and full-width layouts so the active
                 tab keeps exactly one ExecutionGraphCanvas and one LogViewer alive. -->
            <Grid Grid.Row="1"
                  Margin="0"
                  MinHeight="0"
                  ColumnDefinitions="1.7*,6,0.9*"
                  ColumnSpacing="0">
                <Border x:Name="GraphHost"
                        Margin="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Background="{DynamicResource GraphiteTerminalBrush}"
                        BorderBrush="{DynamicResource GraphiteLineBrush}"
                        BorderThickness="0">
                    <controls:ExecutionGraphCanvas Margin="12,10,12,12"
                                                   DataContext="{Binding SelectedGraph}" />
                </Border>

                <!-- Keep the workspace divider in the view layer so users can resize the shared graph and log hosts
                     without pushing layout state into the view model. -->
                <GridSplitter x:Name="GraphLogSplitter"
                              Grid.Column="1"
                              ResizeDirection="Columns"
                              Classes="resize-handle-vertical" />

                <Border x:Name="LogHost"
                        Grid.Column="0"
                        Margin="0"
                        Grid.ColumnSpan="3"
                        Background="{DynamicResource GraphiteTerminalBrush}">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Clear"
                                      Click="ClearLog_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <controls:LogViewer Margin="12,10,12,12"
                                        Entries="{Binding SelectedRuntimeLogEntries}"
                                        SourceKey="{Binding SelectedRuntimeLogSourceId}" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
