<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             xmlns:ext="clr-namespace:LocalAutomation.Extensions.Abstractions;assembly=LocalAutomation.Extensions.Abstractions"
             xmlns:controls="clr-namespace:LocalAutomation.Avalonia.Controls"
             x:Class="LocalAutomation.Avalonia.Views.Panels.OptionsPanel"
             x:DataType="vm:MainWindowViewModel">
    <!-- This panel isolates operation selection and generic responsive option-card layout. -->
    <Border Classes="panel">
        <Grid RowDefinitions="Auto,*,Auto" MinHeight="0">
            <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                    <TextBlock Text="OPERATION" Classes="panel-title" VerticalAlignment="Center" />
                    <!-- Keep the operation control visually present even before it has choices so the dependency on
                         target selection is explained in place instead of by an empty dropdown. -->
                    <ComboBox Grid.Column="1"
                              Width="260"
                              Classes="operation-picker"
                              HorizontalAlignment="Left"
                              IsEnabled="{Binding IsOperationPickerEnabled}"
                              PlaceholderText="{Binding OperationPickerPlaceholderText}"
                              ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding SelectedOperation}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="ext:OperationDescriptor">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0"
                          Padding="10,10,10,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <controls:ResponsiveMeasuredColumns ItemsSource="{Binding EnabledOptionSets}"
                                                    MinimumItemWidth="340"
                                                    MaxColumns="3"
                                                    ColumnSpacing="10"
                                                    RowSpacing="10"
                                                    ViewportHorizontalPadding="0">
                    <controls:ResponsiveMeasuredColumns.ItemTemplate>
                        <DataTemplate x:DataType="vm:OptionSetViewModel">
                            <controls:PropertyCard Title="{Binding Name}"
                                                   PropertyGridTarget="{Binding PropertyGridTarget}" />
                        </DataTemplate>
                    </controls:ResponsiveMeasuredColumns.ItemTemplate>
                </controls:ResponsiveMeasuredColumns>
            </ScrollViewer>

            <!-- The execution-status reason is a full-width footer so long validation details have room and remain
                 easy to copy without crowding the narrow command rail. -->
            <Border Grid.Row="2"
                    IsVisible="{Binding ShowExecuteDisabledReason}"
                    Background="{DynamicResource GraphiteDangerBackgroundBrush}"
                    BorderBrush="{DynamicResource GraphiteDangerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,10,12,12">
                <SelectableTextBlock Text="{Binding ExecuteDisabledReason}"
                                     Classes="status-danger"
                                     TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Border>
</UserControl>
