<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             x:Class="LocalAutomation.Avalonia.Views.Panels.TargetPanel"
             x:DataType="vm:TargetPanelViewModel">
    <!-- This panel isolates target selection and target-scoped actions from the rest of the shell. -->
    <Border Classes="panel" VerticalAlignment="Top">
        <Grid RowDefinitions="Auto,Auto,Auto" MinHeight="0">
            <Border Padding="12,8" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="TARGET" Classes="panel-title" VerticalAlignment="Center" />
                    <!-- Keep settings close to the target workflow now that the custom title bar experiment is removed. -->
                    <Button Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Classes="subtle"
                            Width="24"
                            Height="24"
                            MinWidth="24"
                            MinHeight="24"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="Settings"
                            Click="OpenSettings_Click">
                        <icons:PathIcon Data="M10,1.5 L11.2,1.5 L11.8,3.3 C12.5,3.5 13.1,3.8 13.7,4.1 L15.4,3.2 L16.3,4.1 L15.4,5.8 C15.8,6.3 16.1,6.9 16.3,7.6 L18.1,8.2 L18.1,9.5 L16.3,10.1 C16.1,10.8 15.8,11.4 15.4,11.9 L16.3,13.6 L15.4,14.5 L13.7,13.6 C13.1,14 12.5,14.2 11.8,14.5 L11.2,16.3 L10,16.3 L9.4,14.5 C8.7,14.2 8.1,14 7.5,13.6 L5.8,14.5 L4.9,13.6 L5.8,11.9 C5.4,11.4 5.2,10.8 4.9,10.1 L3.1,9.5 L3.1,8.2 L4.9,7.6 C5.2,6.9 5.4,6.3 5.8,5.8 L4.9,4.1 L5.8,3.2 L7.5,4.1 C8.1,3.8 8.7,3.5 9.4,3.3 Z M10.6,6.2 C9.1,6.2 7.9,7.4 7.9,8.9 C7.9,10.4 9.1,11.6 10.6,11.6 C12.1,11.6 13.3,10.4 13.3,8.9 C13.3,7.4 12.1,6.2 10.6,6.2 Z"
                                        Width="14"
                                        Height="14"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                    </Button>
                </Grid>
            </Border>

            <ComboBox Grid.Row="1"
                      Margin="8,8,8,0"
                      Classes="target-picker"
                      PlaceholderText="{Binding TargetPickerPlaceholderText}"
                      ItemsSource="{Binding TargetPickerItems}"
                      SelectedItem="{Binding SelectedTargetPickerItem}"
                      MaxDropDownHeight="360"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="TargetPicker_SelectionChanged">
                <ComboBox.SelectionBoxItemTemplate>
                    <DataTemplate x:DataType="vm:TargetPickerItemViewModel">
                        <!-- The closed picker gets a slight text inset so the selected target does not feel cramped
                             against the left edge of the card. -->
                        <StackPanel Spacing="2">
                            <!-- Keep the type badge on the title row so the path can use the full available width below. -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0" />
                                <Border Grid.Column="1" Classes="pill" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Right" IsVisible="{Binding IsTargetItem}">
                                    <TextBlock Text="{Binding TypeName}" FontSize="10" FontWeight="Bold" Classes="muted" />
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding TargetPath}" FontSize="12" Classes="muted" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="4,0,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.SelectionBoxItemTemplate>
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:TargetPickerItemViewModel">
                        <Grid>
                            <!-- Target rows reserve the shared close-chip lane so the remove affordance uses the same
                                 edge inset as runtime tabs while leaving the pill and path layout stable. -->
                            <Grid IsVisible="{Binding IsTargetItem}"
                                  RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto,20"
                                  ColumnSpacing="8"
                                  RowSpacing="2">
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0" />
                                <Border Grid.Column="1" Classes="pill" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TypeName}" FontSize="10" FontWeight="Bold" Classes="muted" />
                                </Border>
                                <Button Grid.Column="2"
                                        Grid.RowSpan="2"
                                        Classes="close-chip target-remove"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Click="RemoveTargetPickerItem_Click" />
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding TargetPath}"
                                           FontSize="12"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <Border IsVisible="{Binding IsAddAction}"
                                    Padding="6,4"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <TextBlock Text="{Binding AddActionLabel}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Classes="soft" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Border Grid.Row="2"
                    Margin="8,10,8,8"
                    Padding="0"
                    BorderBrush="{DynamicResource GraphiteLineBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Spacing="6" Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding TargetActions}" Margin="0,0,-8,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- A two-column grid keeps the action row aligned to the panel edges while the
                                     outer negative margin cancels the trailing gutter from per-button spacing. -->
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TargetContextActionViewModel">
                                <Button Classes="small"
                                        Margin="0,0,8,8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Content="{Binding DisplayName}"
                                        Click="TargetAction_Click" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
