<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LocalAutomation.Avalonia.Converters"
             xmlns:vm="clr-namespace:LocalAutomation.Avalonia.ViewModels"
             x:Class="LocalAutomation.Avalonia.Views.Panels.RuntimePanel"
             x:DataType="vm:RuntimePanelViewModel">
    <UserControl.Resources>
        <conv:UppercaseTextConverter x:Key="UppercaseTextConverter" />
    </UserControl.Resources>
    <!-- This panel isolates runtime tabs, log streaming, and runtime cancellation. -->
    <Border Classes="panel">
        <Grid RowDefinitions="Auto,*" MinHeight="0">
            <!-- Keep the tab strip visually integrated with the panel edge instead of floating inside extra header padding. -->
            <Border Padding="0" Background="{DynamicResource GraphiteCardBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="0,0,0,2">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding RuntimeTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuntimeTaskTabViewModel">
                                    <Grid MinHeight="34">
                                        <Button Classes="tab"
                                                Classes.active="{Binding IsSelected}"
                                                Classes.app-log="{Binding IsApplicationLog}"
                                                Classes.closable="{Binding CanClose}"
                                                PointerPressed="RuntimeTab_PointerPressed"
                                                Click="RuntimeTab_Click">
                                            <Button.Content>
                                                <!-- One shared tab-content layout keeps the optional status dot and
                                                     subtitle behavior in a single place for both task tabs and the
                                                     pinned application log tab. -->
                                                <Grid MinHeight="34"
                                                      ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="0">
                                                    <!-- The marker lane owns its own trailing gap so tabs without a status
                                                         dot do not keep a phantom left offset. -->
                                                    <Grid Grid.Column="0"
                                                          Width="12"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          IsVisible="{Binding HasStatusMarker}">
                                                        <Border Width="6"
                                                                Height="6"
                                                                CornerRadius="999"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Classes="runtime-status-dot"
                                                                Classes.running="{Binding IsRunningStatus}"
                                                                Classes.succeeded="{Binding IsSucceededStatus}"
                                                                Classes.failed="{Binding IsFailedStatus}" />
                                                    </Grid>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="0">
                                                        <TextBlock Text="{Binding Title, Converter={StaticResource UppercaseTextConverter}}"
                                                                   Classes="panel-title" />
                                                        <!-- Subtitle rows collapse cleanly for single-line tabs like the app log. -->
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   IsVisible="{Binding HasSubtitle}"
                                                                   Classes="tab-subtitle" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button.Content>
                                        </Button>

                                        <!-- The close affordance uses the same right-edge inset as the target picker. -->
                                        <Button Classes="close-chip"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding CanClose}"
                                                Click="CloseRuntimeTab_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Grid.Column="1"
                            Padding="10,8"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <!-- Selected-task diagnostics stay beside terminate so the active task summary is readable
                             without stealing space from the tab strip itself. -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSelectedRuntimeMetrics}">
                                <Border Classes="pill"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Classes="muted metric-pill-text"
                                               Text="{Binding SelectedRuntimeDuration, StringFormat='TIME {0}'}" />
                                </Border>
                                <Border Classes="pill"
                                        Classes.warning-accent="{Binding SelectedRuntimeTab.HasWarnings}"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Classes="muted metric-pill-text"
                                               Classes.warning-accent="{Binding SelectedRuntimeTab.HasWarnings}"
                                               Text="{Binding SelectedRuntimeWarningCount, StringFormat='WARN {0}'}" />
                                </Border>
                                <Border Classes="pill"
                                        Classes.error-accent="{Binding SelectedRuntimeTab.HasErrors}"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Classes="muted metric-pill-text"
                                               Classes.error-accent="{Binding SelectedRuntimeTab.HasErrors}"
                                               Text="{Binding SelectedRuntimeErrorCount, StringFormat='ERR {0}'}" />
                                </Border>
                            </StackPanel>
                            <Button Classes="danger small"
                                    Content="Terminate"
                                    Click="Terminate_Click"
                                    IsEnabled="{Binding IsRunning}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0" Background="{DynamicResource GraphiteTerminalBrush}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Clear"
                                  Click="ClearLog_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <ScrollViewer x:Name="RuntimeLogScrollViewer"
                              Margin="12,10,12,12"
                              ScrollChanged="RuntimeLogScrollViewer_ScrollChanged"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <!-- One SelectableTextBlock with inline runs preserves per-line coloring while allowing drag
                         selection across the entire log surface. -->
                    <SelectableTextBlock x:Name="RuntimeLogTextBlock"
                                         Classes="mono"
                                         TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
