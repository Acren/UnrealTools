<local:OptionsUserControl x:Class="UnrealCommander.Options.UbtCompilerOptionsControl"
                          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:local="clr-namespace:UnrealCommander.Options"
                          xmlns:unrealCommander="clr-namespace:UnrealCommander"
                          xmlns:operationOptionTypes="clr-namespace:UnrealAutomationCommon.Operations.OperationOptionTypes;assembly=UnrealAutomationCommon"
                          mc:Ignorable="d"
                          d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel VerticalAlignment="Center">
        <!-- Keep compiler and language-standard overrides together because both only apply to direct Build.bat flows. -->
        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Compiler" />
        <ListBox
            ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:UbtCompilerOptionsControl}, Path=Compilers}"
            SelectedValue="{Binding Path=Compiler, Mode=TwoWay}"
            BorderThickness="0" BorderBrush="Transparent" Background="Transparent">
            <ListBox.Resources>
                <unrealCommander:EnumToStringConverter x:Key="EnumToStringConverter" />
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <!-- Hide the default list item chrome so the compiler choices read like explicit radio options. -->
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type operationOptionTypes:UbtCompiler}">
                    <RadioButton Content="{Binding Converter={StaticResource EnumToStringConverter}}"
                                 GroupName="UbtCompilerSelection">
                        <!-- Binding IsChecked to IsSelected keeps the radio group synchronized with the option value. -->
                        <RadioButton.IsChecked>
                            <Binding Path="IsSelected"
                                     RelativeSource="{RelativeSource AncestorType=ListBoxItem}"
                                     Mode="TwoWay" />
                        </RadioButton.IsChecked>
                    </RadioButton>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="C++ Standard" />
        <ListBox
            ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:UbtCompilerOptionsControl}, Path=CppStandards}"
            SelectedValue="{Binding Path=CppStandard, Mode=TwoWay}"
            BorderThickness="0" BorderBrush="Transparent" Background="Transparent">
            <ListBox.Resources>
                <unrealCommander:EnumToStringConverter x:Key="EnumToStringConverter" />
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <!-- Hide the default list item chrome so the language-standard choices read like explicit radio options. -->
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type operationOptionTypes:UbtCppStandard}">
                    <RadioButton Content="{Binding Converter={StaticResource EnumToStringConverter}}"
                                 GroupName="UbtCppStandardSelection">
                        <!-- Binding IsChecked to IsSelected keeps the radio group synchronized with the option value. -->
                        <RadioButton.IsChecked>
                            <Binding Path="IsSelected"
                                     RelativeSource="{RelativeSource AncestorType=ListBoxItem}"
                                     Mode="TwoWay" />
                        </RadioButton.IsChecked>
                    </RadioButton>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</local:OptionsUserControl>
