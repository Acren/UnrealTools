<Project>

  <!--
    Centralized bundled-extension declarations keep host and extension projects generic while still wiring the Unreal
    extension into the Unreal Commander launcher output.
  -->
  <ItemGroup Condition="'$(MSBuildProjectName)' == 'UnrealCommander.Avalonia'">
    <!-- The launcher depends on the Unreal extension build, but the extension's own build target owns the payload copy
         so IDE builds that stop at the extension still refresh the runtime bundle. -->
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\LocalAutomation.Extensions.Unreal\LocalAutomation.Extensions.Unreal.csproj"
                       ReferenceOutputAssembly="false"
                       PrivateAssets="all" />
  </ItemGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'LocalAutomation.Extensions.Unreal'">
    <!-- The Unreal extension is loaded from the launcher output's Extensions folder, so building the extension must
         mirror its output there without requiring the launcher project to run a separate copy target. -->
    <HasBundledExtensionHost>true</HasBundledExtensionHost>
    <BundledExtensionHostRoot>$(MSBuildThisFileDirectory)..\UnrealCommander.Avalonia\</BundledExtensionHostRoot>
    <BundledExtensionFolderName>Unreal</BundledExtensionFolderName>
  </PropertyGroup>

</Project>
