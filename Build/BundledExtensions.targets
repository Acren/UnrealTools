<Project>

  <!--
    Keep bundled-extension copy logic on the extension project itself so builds that compile the extension without
    rebuilding the launcher still refresh the runtime payload consumed by AppContext.BaseDirectory-based discovery.
  -->
  <PropertyGroup Condition="'$(HasBundledExtensionHost)' == 'true'">
    <!-- The launcher and extension currently target the same framework, which keeps the runtime bundle path tied to the
         extension build that produced the files being copied. -->
    <BundledExtensionsRoot>$(BundledExtensionHostRoot)bin\$(Configuration)\$(TargetFramework)\Extensions\</BundledExtensionsRoot>
    <BundledExtensionDestinationRoot>$(BundledExtensionsRoot)$(BundledExtensionFolderName)\</BundledExtensionDestinationRoot>
    <BundledExtensionsStampPath>$(BundledExtensionsRoot).bundled-extensions.stamp</BundledExtensionsStampPath>
  </PropertyGroup>

  <ItemGroup Condition="'$(HasBundledExtensionHost)' == 'true'">
    <!-- These assemblies are provided by the launcher's default load context and must not be duplicated in the isolated
         extension folder, otherwise extension modules can bind to different contract/runtime types than the host. -->
    <BundledExtensionSharedAssembly Include="LocalAutomation.Application.dll;LocalAutomation.Application.pdb;LocalAutomation.Core.dll;LocalAutomation.Core.pdb;LocalAutomation.Extensions.Abstractions.dll;LocalAutomation.Extensions.Abstractions.pdb;LocalAutomation.Runtime.dll;LocalAutomation.Runtime.pdb" />
  </ItemGroup>

  <Target Name="CopyBundledExtensionToHost"
          AfterTargets="Build"
          Condition="'$(HasBundledExtensionHost)' == 'true'">

    <ItemGroup>
      <!-- Expand the extension build output inside the target so referenced package files copied during Build are part
           of the mirrored payload. -->
      <BundledExtensionFiles Include="$(TargetDir)**\*.*"
                             Exclude="@(BundledExtensionSharedAssembly->'$(TargetDir)%(Identity)')" />
      <!-- Pre-create nested destination folders so the Copy task can mirror satellite assemblies, runtimes, and
           template folders without relying on stale directories from previous builds. -->
      <BundledExtensionDirectories Include="@(BundledExtensionFiles->'$(BundledExtensionDestinationRoot)%(RecursiveDir)')" />
    </ItemGroup>

    <!-- A bundled extension build without output is invalid because the launcher would otherwise keep running whatever
         payload happened to be left in its Extensions directory. -->
    <Error Condition="'@(BundledExtensionFiles)' == ''"
           Text="Bundled extension '$(MSBuildProjectName)' produced no files in '$(TargetDir)', so the launcher runtime bundle cannot be refreshed." />

    <!-- Remove a destination stamp if present because extension freshness is defined by this target copying the build
         output, not by a separate host-side up-to-date file. -->
    <Delete Files="$(BundledExtensionsStampPath)" Condition="Exists('$(BundledExtensionsStampPath)')" />
    <!-- Remove only this extension's payload so stale files disappear without disturbing other bundled extensions. -->
    <RemoveDir Directories="$(BundledExtensionDestinationRoot)" Condition="Exists('$(BundledExtensionDestinationRoot)')" />
    <MakeDir Directories="$(BundledExtensionDestinationRoot)" />
    <Message Importance="High" Text="Copying bundled extension '$(BundledExtensionFolderName)' to '$(BundledExtensionDestinationRoot)'." />

    <MakeDir Directories="@(BundledExtensionDirectories)" Condition="@(BundledExtensionDirectories) != ''" />

    <!-- Copy the current extension output after clearing the destination so the launched app never observes an older
         dependency set than the extension project just built. -->
    <Copy SourceFiles="@(BundledExtensionFiles)"
          DestinationFiles="@(BundledExtensionFiles->'$(BundledExtensionDestinationRoot)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="@(BundledExtensionFiles) != ''" />

    <!-- Write the stamp only after the payload copy succeeds so tooling and humans can distinguish a refreshed bundle
         from an older bundle left behind by a failed copy. -->
    <WriteLinesToFile File="$(BundledExtensionsStampPath)"
                      Lines="$(MSBuildProjectFullPath);$(TargetPath);$(Configuration);$(TargetFramework)"
                      Overwrite="true" />
  </Target>

</Project>
