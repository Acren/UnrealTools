<Project>

  <!--
    Keep bundled-extension copy logic shared so multiple launcher executables can emit the same compile-time extension
    set without duplicating the target in every host project file.
  -->
  <PropertyGroup Condition="'$(HasBundledExtensionProjects)' == 'true'">
    <!-- Keep the bundled extension payload under the launched app's output directory because the runtime loader uses
         AppContext.BaseDirectory as the extension discovery root. -->
    <BundledExtensionsRoot>$(OutputPath)Extensions\</BundledExtensionsRoot>
    <BundledExtensionsStamp>$(BundledExtensionsRoot).bundled-extensions.stamp</BundledExtensionsStamp>
  </PropertyGroup>

  <ItemGroup Condition="'$(HasBundledExtensionProjects)' == 'true'">
    <BundledExtensionProject Update="@(BundledExtensionProject)">
      <!-- Default bundled extensions to the consuming host's target framework so framework retargets do not require
           a second hardcoded path update. Individual extensions can still provide ExtensionTargetFramework metadata
           later if they intentionally diverge from the host. -->
      <SourceRoot Condition="'%(BundledExtensionProject.ExtensionTargetFramework)' != ''">%(RootDir)%(Directory)bin\$(Configuration)\%(BundledExtensionProject.ExtensionTargetFramework)\</SourceRoot>
      <SourceRoot Condition="'%(BundledExtensionProject.ExtensionTargetFramework)' == ''">%(RootDir)%(Directory)bin\$(Configuration)\$(TargetFramework)\</SourceRoot>
      <ProjectRoot>%(RootDir)%(Directory)</ProjectRoot>
    </BundledExtensionProject>

    <!-- IDE fast-up-to-date checks need explicit bundled-extension inputs because the launcher output depends on files
         copied by this custom target rather than on normal ReferenceOutputAssembly references. -->
    <BundledExtensionSourceInput Include="%(BundledExtensionProject.ProjectRoot)**\*.cs;%(BundledExtensionProject.ProjectRoot)**\*.csproj;@(BundledExtensionUpToDateInputRoot->'%(Identity)**\*.cs');@(BundledExtensionUpToDateInputRoot->'%(Identity)**\*.csproj')"
                                  Exclude="%(BundledExtensionProject.ProjectRoot)bin\**;%(BundledExtensionProject.ProjectRoot)obj\**;@(BundledExtensionUpToDateInputRoot->'%(Identity)bin\**');@(BundledExtensionUpToDateInputRoot->'%(Identity)obj\**')" />

    <!-- The extension build output is also an input: referenced libraries copied into the extension output must make the
         host's bundled payload stale even when no extension source file changed. -->
    <BundledExtensionBuildInput Include="%(BundledExtensionProject.SourceRoot)**\*.*" />

    <BundledExtensionCopyInput Include="$(MSBuildThisFileFullPath);$(MSBuildProjectFullPath);@(BundledExtensionSourceInput);@(BundledExtensionBuildInput)" />
    <UpToDateCheckInput Include="@(BundledExtensionCopyInput)" />
    <UpToDateCheckOutput Include="$(BundledExtensionsStamp)" />
  </ItemGroup>

  <Target Name="CopyBundledExtensions"
          AfterTargets="Build"
          Inputs="@(BundledExtensionCopyInput)"
          Outputs="$(BundledExtensionsStamp)"
          Condition="'$(HasBundledExtensionProjects)' == 'true'">

    <RemoveDir Directories="$(BundledExtensionsRoot)" Condition="Exists('$(BundledExtensionsRoot)')" />
    <MakeDir Directories="$(BundledExtensionsRoot)" />
    <Message Importance="High" Text="Copying bundled extensions to '$(BundledExtensionsRoot)'." />

    <ItemGroup>
      <!-- Batch directly on each bundled extension project so wildcard expansion happens against a concrete source
           root instead of being treated as a literal transformed path. -->
      <BundledExtensionFiles Include="%(BundledExtensionProject.SourceRoot)**\*.*"
                             Exclude="%(BundledExtensionProject.SourceRoot)LocalAutomation.Application.dll;%(BundledExtensionProject.SourceRoot)LocalAutomation.Application.pdb;%(BundledExtensionProject.SourceRoot)LocalAutomation.Core.dll;%(BundledExtensionProject.SourceRoot)LocalAutomation.Core.pdb;%(BundledExtensionProject.SourceRoot)LocalAutomation.Extensions.Abstractions.dll;%(BundledExtensionProject.SourceRoot)LocalAutomation.Extensions.Abstractions.pdb;%(BundledExtensionProject.SourceRoot)LocalAutomation.Runtime.dll;%(BundledExtensionProject.SourceRoot)LocalAutomation.Runtime.pdb">
        <ExtensionFolderName>%(BundledExtensionProject.ExtensionFolderName)</ExtensionFolderName>
      </BundledExtensionFiles>
      <BundledExtensionDirectories Include="@(BundledExtensionFiles->'$(BundledExtensionsRoot)%(ExtensionFolderName)\%(RecursiveDir)')" />
    </ItemGroup>

    <MakeDir Directories="@(BundledExtensionDirectories)" Condition="@(BundledExtensionDirectories) != ''" />

    <Copy SourceFiles="@(BundledExtensionFiles)"
          DestinationFiles="@(BundledExtensionFiles->'$(BundledExtensionsRoot)%(ExtensionFolderName)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="@(BundledExtensionFiles) != ''" />
    <Touch Files="$(BundledExtensionsStamp)" AlwaysCreate="true" />
  </Target>

</Project>
